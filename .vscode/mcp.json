{
  "servers": {
    "mikrotik": {
      "type": "stdio",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "-m",
        "mcp_help.servers.mikrotik.server",
        "--env-file",
        "${workspaceFolder}/.mcp-local/mikrotik.env"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
